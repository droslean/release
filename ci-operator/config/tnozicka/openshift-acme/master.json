{
  "base_images": {
    "os": {
      "cluster": "https://api.ci.openshift.org",
      "namespace": "openshift",
      "name": "centos",
      "tag": "7"
    }
  },
  "test_base_image": {
    "cluster": "https://api.ci.openshift.org",
    "namespace": "openshift",
    "name": "release",
    "tag": "golang-1.10"
  },

  "canonical_go_repository": "github.com/tnozicka/openshift-acme",

  "binary_build_commands": "make build GOFLAGS='-v'",
  "test_binary_build_commands": "make build GOFLAGS='-v -race'",

  "images": [
    {
      "from": "os",
      "to": "openshift-acme",
      "dockerfile_path": "images/Dockerfile",
      "inputs": {
        "bin": {
          "as": ["bin"]
        }
      }
    }
  ],

  "tests": [
    {
      "as": "verify",
      "from": "bin",
      "commands": "ARTIFACT_DIR=/tmp/artifacts make verify -k",
      "artifact_dir": "/tmp/artifacts"
    },
    {
      "as": "unit",
      "from": "test-bin",
      "commands": "ARTIFACT_DIR=/tmp/artifacts make test",
      "artifact_dir": "/tmp/artifacts"
    },
    {
      "as": "e2e",
      "from": "bin",
      "commands": "ARTIFACT_DIR=/tmp/artifacts make test-extended",
      "artifact_dir": "/tmp/artifacts",
      "inputs": {
        "openshift-acme": {}
      }
    }
  ],

  "resources": {
    "*": {
      "requests": { "cpu": "100m", "memory": "200Mi" },
      "limits":   { "cpu": "2",    "memory": "6Gi" }
    },
    "bin": {
      "requests": { "cpu": "3",    "memory": "7Gi" },
      "limits":   { "cpu": "7",    "memory": "11Gi" }
    },
    "unit": {
      "requests": { "cpu": "3",    "memory": "5Gi" },
      "limits":   { "cpu": "7",    "memory": "11Gi" }
    },
    "verify": {
      "requests": { "cpu": "2",    "memory": "6Gi" },
      "limits":   { "cpu": "6",    "memory": "11Gi" }
    }
  }
}